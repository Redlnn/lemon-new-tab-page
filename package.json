{
  "name": "lemon-new-tab",
  "version": "3.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "vue-tsc --build && wxt build",
    "build:firefox": "vue-tsc --build && wxt build -b firefox",
    "build:edge": "vue-tsc --build && wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "postinstall": "wxt prepare",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint:style": "stylelint **/*.{css,scss,sass,less,vue,html} --fix --ignore-path .gitignore",
    "lint": "run-s lint:*",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@vicons/antd": "^0.13.0",
    "@vicons/fa": "^0.13.0",
    "@vicons/fluent": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "dayjs-plugin-lunar": "^1.4.1",
    "element-plus": "^2.13.5",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-vue": "^5.4.0",
    "jinrishici": "^1.0.6",
    "localforage": "^1.10.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "@wxt-dev/webextension-polyfill": "^1.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-vue": "^10.8.0",
    "markdown-exit": "latest",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "sass-embedded": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-markdown": "^30.0.0",
    "vite": "^8.0.0",
    "vite-plugin-i18next-loader": "^3.1.3",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.2.5",
    "webextension-polyfill": "^0.12.0",
    "wxt": "^0.20.19"
  },
  "pnpm": {
    "overrides": {
      "glob": "^13.0.6",
      "markdown-it": "npm:markdown-exit@latest",
      "uuid": "^13.0.0",
      "sass": "npm:sass-embedded@^1.98.0",
      "vite": "^8.0.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint"
      ],
      "allowAny": [
        "eslint"
      ]
    }
  }
}
